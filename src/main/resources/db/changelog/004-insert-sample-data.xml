    <changeSet id="004-insert-sample-authors" author="ggardet">
        <insert tableName="authors">
            <column name="first_name" value="Victor"/>
            <column name="last_name" value="Hugo"/>
            <column name="nationality" value="French"/>
            <column name="birth_year" value="1802"/>
            <column name="biography" value="Victor-Marie Hugo was a French poet, novelist, and dramatist of the Romantic movement. He is considered one of the greatest and best-known French writers."/>
        </insert>
        
        <insert tableName="authors">
            <column name="first_name" value="Jane"/>
            <column name="last_name" value="Austen"/>
            <column name="nationality" value="British"/>
            <column name="birth_year" value="1775"/>
            <column name="biography" value="Jane Austen was an English novelist known primarily for her six major novels, which interpret, critique and comment upon the British landed gentry at the end of the 18th century."/>
        </insert>
        
        <insert tableName="authors">
            <column name="first_name" value="Gabriel"/>
            <column name="last_name" value="García Márquez"/>
            <column name="nationality" value="Colombian"/>
            <column name="birth_year" value="1927"/>
            <column name="biography" value="Gabriel José de la Concordia García Márquez was a Colombian novelist, short-story writer, screenwriter, and journalist, known affectionately as Gabo throughout Latin America."/>
        </insert>
    </changeSet>

